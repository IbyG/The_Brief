{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://example.com/schemas/story-frame.schema.json",
    "title": "Story Frame",
    "type": "object",
    "additionalProperties": false,
    "date": "dd/mm/yyyy",
    "time": "hh:mm:ss",
    "tags": "",
    "required": ["rank", "headline", "sections"],
    "properties": {
      "rank": {
        "type": "integer",
        "minimum": 1
      },
      "headline": {
        "type": "string",
        "minLength": 1
      },
      "date_confirmed": {
        "type": "string",
        "format": "date"
      },
      "sources_confirmed": {
        "type": "array",
        "items": {
          "type": "string",
          "minLength": 1
        },
        "uniqueItems": true
      },
      "summary": {
        "type": "string"
      },
      "sections": {
        "type": "array",
        "items": {
          "$ref": "#/$defs/section"
        }
      },
      "meta": {
        "$ref": "#/$defs/meta"
      }
    },
    "$defs": {
      "meta": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "topic": { "type": "string" },
          "audience": { "type": "string" },
          "priority": { "type": "string" },
          "tags": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      },
      "section": {
        "oneOf": [
          { "$ref": "#/$defs/bulletListSection" },
          { "$ref": "#/$defs/cardsSection" },
          { "$ref": "#/$defs/linksSection" },
          { "$ref": "#/$defs/timelineSection" },
          { "$ref": "#/$defs/quoteSection" },
          { "$ref": "#/$defs/statsSection" },
          { "$ref": "#/$defs/genericSection" }
        ]
      },
      "baseSection": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "type", "title", "items"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$"
          },
          "type": {
            "type": "string"
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string"
          },
          "items": {
            "type": "array"
          }
        }
      },
      "bulletListSection": {
        "allOf": [
          { "$ref": "#/$defs/baseSection" },
          {
            "properties": {
              "type": { "const": "bullet_list" },
              "items": {
                "type": "array",
                "items": { "$ref": "#/$defs/bulletItem" }
              }
            }
          }
        ]
      },
      "cardsSection": {
        "allOf": [
          { "$ref": "#/$defs/baseSection" },
          {
            "properties": {
              "type": { "const": "cards" },
              "items": {
                "type": "array",
                "items": { "$ref": "#/$defs/cardItem" }
              }
            }
          }
        ]
      },
      "linksSection": {
        "allOf": [
          { "$ref": "#/$defs/baseSection" },
          {
            "properties": {
              "type": { "const": "links" },
              "items": {
                "type": "array",
                "items": { "$ref": "#/$defs/linkItem" }
              }
            }
          }
        ]
      },
      "timelineSection": {
        "allOf": [
          { "$ref": "#/$defs/baseSection" },
          {
            "properties": {
              "type": { "const": "timeline" },
              "items": {
                "type": "array",
                "items": { "$ref": "#/$defs/timelineItem" }
              }
            }
          }
        ]
      },
      "quoteSection": {
        "allOf": [
          { "$ref": "#/$defs/baseSection" },
          {
            "properties": {
              "type": { "const": "quotes" },
              "items": {
                "type": "array",
                "items": { "$ref": "#/$defs/quoteItem" }
              }
            }
          }
        ]
      },
      "statsSection": {
        "allOf": [
          { "$ref": "#/$defs/baseSection" },
          {
            "properties": {
              "type": { "const": "stats" },
              "items": {
                "type": "array",
                "items": { "$ref": "#/$defs/statItem" }
              }
            }
          }
        ]
      },
      "genericSection": {
        "allOf": [
          { "$ref": "#/$defs/baseSection" },
          {
            "properties": {
              "type": { "const": "generic" },
              "items": {
                "type": "array",
                "items": { "$ref": "#/$defs/contentBlock" }
              }
            }
          }
        ]
      },
      "bulletItem": {
        "type": "object",
        "additionalProperties": false,
        "required": ["text"],
        "properties": {
          "text": { "type": "string", "minLength": 1 },
          "note": { "type": "string" }
        }
      },
      "cardItem": {
        "type": "object",
        "additionalProperties": false,
        "required": ["title", "description"],
        "properties": {
          "category": { "type": "string" },
          "title": { "type": "string", "minLength": 1 },
          "description": { "type": "string", "minLength": 1 },
          "cta_label": { "type": "string" },
          "cta_url": { "type": "string", "format": "uri" }
        }
      },
      "linkItem": {
        "type": "object",
        "additionalProperties": false,
        "required": ["label", "url"],
        "properties": {
          "label": { "type": "string", "minLength": 1 },
          "url": { "type": "string", "format": "uri" },
          "source": { "type": "string" }
        }
      },
      "timelineItem": {
        "type": "object",
        "additionalProperties": false,
        "required": ["text"],
        "properties": {
          "date": { "type": "string" },
          "text": { "type": "string", "minLength": 1 }
        }
      },
      "quoteItem": {
        "type": "object",
        "additionalProperties": false,
        "required": ["quote"],
        "properties": {
          "quote": { "type": "string", "minLength": 1 },
          "speaker": { "type": "string" },
          "role": { "type": "string" }
        }
      },
      "statItem": {
        "type": "object",
        "additionalProperties": false,
        "required": ["label", "value"],
        "properties": {
          "label": { "type": "string", "minLength": 1 },
          "value": {
            "oneOf": [
              { "type": "string" },
              { "type": "number" },
              { "type": "integer" }
            ]
          },
          "context": { "type": "string" }
        }
      },
      "contentBlock": {
        "oneOf": [
          { "$ref": "#/$defs/bulletBlock" },
          { "$ref": "#/$defs/textBlock" },
          { "$ref": "#/$defs/linkBlock" },
          { "$ref": "#/$defs/statBlock" },
          { "$ref": "#/$defs/quoteBlock" }
        ]
      },
      "bulletBlock": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "text"],
        "properties": {
          "kind": { "const": "bullet" },
          "text": { "type": "string", "minLength": 1 }
        }
      },
      "textBlock": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "text"],
        "properties": {
          "kind": { "const": "text" },
          "text": { "type": "string", "minLength": 1 }
        }
      },
      "linkBlock": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "label", "url"],
        "properties": {
          "kind": { "const": "link" },
          "label": { "type": "string", "minLength": 1 },
          "url": { "type": "string", "format": "uri" }
        }
      },
      "statBlock": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "label", "value"],
        "properties": {
          "kind": { "const": "stat" },
          "label": { "type": "string", "minLength": 1 },
          "value": {
            "oneOf": [
              { "type": "string" },
              { "type": "number" },
              { "type": "integer" }
            ]
          }
        }
      },
      "quoteBlock": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "quote"],
        "properties": {
          "kind": { "const": "quote" },
          "quote": { "type": "string", "minLength": 1 },
          "speaker": { "type": "string" }
        }
      }
    }
  }